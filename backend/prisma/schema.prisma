generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  user
  admin
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
  address     String
  city        String
  latitude    Float
  longitude   Float
  bannerImage String
  organizer   String
  contact     String
  startDate   DateTime
  endDate     DateTime
  isPublished Boolean  @default(false)
  popularity  Int      @default(0)
  gallery     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
